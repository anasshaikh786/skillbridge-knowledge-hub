# SkillBridge backend env — copy this to .env
MONGO_URL="mongodb://localhost:27017/skillbridge"
PORT=8001
CORS_ORIGINS="http://localhost:3000"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRE_HOURS=72

# Resend (email) — leave empty for MOCK mode
RESEND_API_KEY=""
RESEND_FROM_EMAIL="SkillBridge <onboarding@resend.dev>"

# Cloudinary — leave empty for MOCK mode
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay — leave empty for MOCK mode
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
